rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /leaderboard/{doc} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly(['name', 'score', 'total', 'mode', 'timeSec', 'timestamp'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 20
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 10
        && request.resource.data.total is int
        && request.resource.data.total > 0
        && request.resource.data.total <= 20
        && request.resource.data.mode in ['easy', 'hard', 'gen1', 'types']
        && request.resource.data.timeSec is int
        && request.resource.data.timeSec >= 0
        && request.resource.data.timeSec <= 3600;

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
